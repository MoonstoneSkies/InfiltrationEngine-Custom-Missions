		<Item class="StringValue" referent="RBX9C880CFEA236498290D8B6BB2ED0CCF3">
			<Properties>
				<string name="Value"><![CDATA[-- This asset is licensed under Creative Commons BY-NC-SA 4.0

--[[
	This is a simple baseplate that also demonstrates how to define custom strings
	Any custom strings you use must be added through this file
]]

return {
	CustomStrings = {
		["Operator.Any.Intro1"] = "Welcome to the baseplate template",
		["Operator.Any.Intro2.1"] = "Not much here is there?",
		["Operator.Any.Intro2.2"] = "It also serves as a custom dialogue sample"
	},
	Dialogue = {
		MissionEnter = {
			{"Operator.Any.Intro1", {"Operator.Any.Intro2.1", "Operator.Any.Intro2.2"}},
		}	
	},
	
	Globals = {
		MissionComplete = "1"	
	},
	Internals = {},
	ClientState = {},
	
	HackingMapIntel = {},

	LightingSettings = "Daytime",
	SoundTravelDistance = 1,
	
	Colors = {
		Wood = Color3.fromRGB(99, 95, 98),
		WoodLight = Color3.fromRGB(149, 137, 136),
		Metal = Color3.fromRGB(105, 106, 113),
	},
	CameraConfig = {
		Main = {
			OperatorTag = "CamOperator",
			RoomTag = "SecurityCenter",
		}
	},
	Cells = {
		Default = {
			Trespass = false,
		},
	},
	EnforceClass = {
		None = {}, -- Never sees through disguise
		Alert0 = {
			BasicSecurity = 1, -- Sees through disguise when alert
		},
		Alert1 = {
			BasicSecurity = 2, -- Sees through disguise when normal
		},
		Alert2 = {
			BasicSecurity = 5, -- Always sees through disguise
		},
	},
	Objectives = {
		Mission = { -- Normal
			{
				Active = "1", -- No Objective will be shown if the active stage doesn't define Text
			},
			{
