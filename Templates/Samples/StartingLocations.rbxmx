		<Item class="ModuleScript" referent="RBX5CFD0DF7D21741C091D247DCAB7AC1EC">
			<Properties>
				<Content name="LinkedSource"><null></null></Content>
				<ProtectedString name="Source"><![CDATA[-- This asset is licensed under Creative Commons BY-NC-SA 4.0

--[[
	This template provides a sample for setting up entry points and custom mission descriptions.
]]

return {
	CustomStrings = {
		["Title.CustomMission"] = "Custom Mission Title",
		["UI.CustomMissionLongDesc"] = "This template provides a sample for setting up entry points and custom mission descriptions. See the Preplanning table in MissionSetup for examples",
		["UI.SampleFinanancierEntryPoints"] = "Entry Point Samples (Financier)",
		["StartingLocation.DisguiseSample"] = "Disguise Sample",
		["StartingLocation.DisguiseSample.Desc"] = "Starting location that includes a security disguise",
	},
	Dialogue = {},
	
	Globals = {
		MissionComplete = "1"	
	},
	Internals = {},
	ClientState = {},
	
	HackingMapIntel = {},

	LightingSettings = "Daytime",
	SoundTravelDistance = 1,
	
	Colors = {
		Wood = Color3.fromRGB(99, 95, 98),
		WoodLight = Color3.fromRGB(149, 137, 136),
		Metal = Color3.fromRGB(105, 106, 113),
	},
	CameraConfig = {
		Main = {
			OperatorTag = "CamOperator",
			RoomTag = "SecurityCenter",
		}
	},
	Cells = {
		Default = {
			Trespass = false,
		},
	},
	EnforceClass = {
		None = {}, -- Never sees through disguise
		Alert0 = {
			BasicSecurity = 1, -- Sees through disguise when alert
		},
		Alert1 = {
			BasicSecurity = 2, -- Sees through disguise when normal
		},
		Alert2 = {
			BasicSecurity = 5, -- Always sees through disguise
		},
	},
	Objectives = {
		Mission = { -- Normal
			{
				Active = "1", -- No Objective will be shown if the active stage doesn't define Text
			},
			{
				Active = "MissionComplete",
				Text = "Objective.Exfiltrate",
				Tag = "MissionExit",
			},
		},
		Stealth = {
		},
		Combat = {
		},
	},
	
	Preplanning = {
		MissionTitle = "Title.CustomMission",
		MissionDescription = "UI.CustomMissionLongDesc",
		StartingLocationTitle = "UI.SampleFinanancierEntryPoints",
		StartingLocation = {
			{
				Id = "Default",
				Title = "StartingLocation.MainElevator",
				Subtitle = "StartingLocation.MainElevator.Desc",
				Tags = {
					{
						Type = "ARMS_RAISE_ALARMS",
					},
				},
			},
			{
				Id = "UtilityRoom",
				Title = "StartingLocation.FinancierUtilityRoom",
				Subtitle = "StartingLocation.FinancierUtilityRoom.Desc",
				Tags = {
					{
						Type = "REQUIRES_PERK",
						Tooltip = "Tooltip.RequiresSkillSocialEngineering 2",
						Perks = {
							{ SocialEngineering = 2 },
						}
					}
				},
			},
			{
				Id = "RyansBalcony",
				Title = "StartingLocation.RyansBalcony",
				Subtitle = "StartingLocation.RyansBalcony.Desc",
				Tags = {
					{
						Type = "ARMS_RAISE_ALARMS",
					},
					{
						Type = "REQUIRES_PERK",
						Tooltip = "Tooltip.RequiresSkillRyansBalcony",
						Perks = {
							{ Climber = 3 },
							{ Climber = 2, LockArtist = 2},
						}
					}
				},
			},
			{
				Id = "DisguiseSample",
				Title = "StartingLocation.DisguiseSample",
				Subtitle = "StartingLocation.DisguiseSample.Desc",
				Disguise = "BasicSecurity",
				UsedVariable = "DisguiseEntranceUsed",
				Tags = {},
			},
		}
	}
	
}
]]></ProtectedString>
